# App
APP_NAME=OciPulse
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# OCI Configuration
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_REGION=us-ashburn-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-id

# Kubernetes
K8S_CONFIG_FILE=~/.kube/config
K8S_IN_CLUSTER=false

# Set to true to use mock data (no OCI/K8s credentials needed)
USE_MOCK_DATA=true

# SMTP Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=alerts@yourcompany.com
ALERT_EMAIL_TO=oncall@yourcompany.com

# Thresholds
CPU_ALERT_THRESHOLD=80
MEMORY_ALERT_THRESHOLD=85
ERROR_RATE_ALERT_THRESHOLD=10