# ── Frontend build-time environment variables ──────────────────────────────────
#
# Copy this to frontend/.env  then run: npm run build
#
# VITE_API_URL
#   Leave empty (default) when using docker-compose — nginx proxies /api/* to
#   the backend container automatically.
#
#   Set this ONLY when:
#     • You are running the backend directly on the VM (no nginx proxy), OR
#     • The nginx proxy isn't reachable and you need to hit the backend directly
#
#   Examples:
#     VITE_API_URL=http://10.0.1.50:8000/api      ← VM private IP + backend port
#     VITE_API_URL=http://monitor.internal/api     ← internal DNS
#
# IMPORTANT: After changing this file you must rebuild the frontend:
#     docker-compose build frontend
#     docker-compose up -d frontend
#
VITE_API_URL=
