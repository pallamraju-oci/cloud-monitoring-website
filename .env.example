# ═══════════════════════════════════════════════════════════════════════════════
# OciPulse — VM Deployment Environment File
#
# Copy this file:   cp .env.example .env
# Then fill in the values below.
# The .env file is read by docker-compose and by the FastAPI app (python-dotenv).
# ═══════════════════════════════════════════════════════════════════════════════


# ── Application ────────────────────────────────────────────────────────────────

APP_NAME=OciPulse
DEBUG=false

# Generate a strong random key:  openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32_output

# JWT expiry in minutes (60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Port the Nginx container listens on (host side)
FRONTEND_PORT=80


# ── CORS — allowed browser origins ─────────────────────────────────────────────
#
# Add every URL users will open in their browser.
# Examples:
#   http://10.0.1.50           — private VM IP
#   http://ocipulse.internal   — internal DNS name
#   https://monitor.myco.com   — public domain (if you add TLS)
#
CORS_ORIGINS=["http://YOUR_VM_PRIVATE_IP","http://YOUR_VM_PUBLIC_IP","http://localhost"]


# ── OCI Authentication ─────────────────────────────────────────────────────────
#
# RECOMMENDED FOR OCI VMs: instance_principal
#   - No API keys or config files needed on the VM.
#   - Assign a Dynamic Group to your instance and attach an IAM policy:
#
#       Dynamic Group (match rule):
#         ANY {instance.id = 'ocid1.instance.oc1..YOUR_INSTANCE_OCID'}
#         -- or for all instances in a compartment:
#         ANY {instance.compartment.id = 'ocid1.compartment.oc1..YOUR_COMPARTMENT'}
#
#       IAM Policy (attach to the dynamic group):
#         Allow dynamic-group <DG_NAME> to read all-resources in compartment <NAME>
#         Allow dynamic-group <DG_NAME> to use metrics in compartment <NAME>
#         Allow dynamic-group <DG_NAME> to read log-content in compartment <NAME>
#
# OTHER OPTIONS:
#   config_file       — reads OCI_CONFIG_FILE (API key; good for local dev)
#   resource_principal— for OCI Functions / container instances
#
OCI_AUTH_TYPE=instance_principal

# Only needed when OCI_AUTH_TYPE=config_file:
# OCI_CONFIG_FILE=/root/.oci/config
# OCI_PROFILE=DEFAULT

# Directory containing your ~/.oci folder (mounted read-only into the container).
# Only relevant when OCI_AUTH_TYPE=config_file.
OCI_CONFIG_DIR=~/.oci

# Optional: kubeconfig directory (mounted into the container)
KUBE_CONFIG_DIR=~/.kube


# ── OCI Region ─────────────────────────────────────────────────────────────────
#
# Use your tenancy's home region or the region where resources live.
# Common regions:
#   ap-mumbai-1       India West (Mumbai)
#   ap-hyderabad-1    India East (Hyderabad)
#   us-ashburn-1      US East (Ashburn)
#   us-phoenix-1      US West (Phoenix)
#   eu-frankfurt-1    Germany Central
#   uk-london-1       UK South (London)
#
OCI_REGION=ap-mumbai-1


# ── Compartments ───────────────────────────────────────────────────────────────
#
# SINGLE COMPARTMENT — simple setup:
#OCI_COMPARTMENT_ID=ocid1.compartment.oc1..aaaaaaaa_YOUR_COMPARTMENT_OCID
#
# MULTIPLE COMPARTMENTS — comma-separated OCIDs (no spaces):
# OciPulse will query ALL compartments and aggregate results.
#
OCI_COMPARTMENT_IDS=ocid1.compartment.oc1..COMPARTMENT_A,ocid1.compartment.oc1..COMPARTMENT_B,ocid1.compartment.oc1..COMPARTMENT_C
#
# Human-readable labels for each compartment (same order, comma-separated).
# These labels appear in the UI next to each resource.
#
OCI_COMPARTMENT_LABELS=prod,stage,shared-infra


# ── Kubernetes ─────────────────────────────────────────────────────────────────
#
# Set K8S_IN_CLUSTER=true if OciPulse is deployed inside the OKE cluster itself.
# Set K8S_IN_CLUSTER=false and provide a kubeconfig to monitor a remote cluster.
#
K8S_IN_CLUSTER=false
K8S_CONFIG_FILE=/root/.kube/config
#
# If your OKE cluster is on a private subnet, the VM running OciPulse must:
#   - Be in the same VCN (or a peered VCN)
#   - Have a security list / NSG rule allowing TCP 6443 to the OKE API server
#   - Have the kubeconfig file from: oci ce cluster create-kubeconfig ...
#


# ── Mock Data ──────────────────────────────────────────────────────────────────
#
# true  → use realistic generated data (no OCI credentials required)
# false → connect to real OCI APIs (requires OCI_AUTH_TYPE configured above)
#
USE_MOCK_DATA=false


# ── Alert Thresholds ───────────────────────────────────────────────────────────

CPU_ALERT_THRESHOLD=80
MEMORY_ALERT_THRESHOLD=85
ERROR_RATE_ALERT_THRESHOLD=10


# ── SMTP Email Alerts ──────────────────────────────────────────────────────────
#
# Used to send alert notifications when thresholds are breached.
# For Gmail: enable 2FA and create an App Password (not your main password).
# Alternatively use OCI Email Delivery SMTP endpoint:
#   Host: smtp.email.<region>.oci.oraclecloud.com   Port: 587
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-alerts@gmail.com
SMTP_PASSWORD=your-app-password-here
ALERT_EMAIL_FROM=ocipulse-alerts@yourcompany.com
ALERT_EMAIL_TO=oncall@yourcompany.com
